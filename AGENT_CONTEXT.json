{
  "schema_version": "1.0.0",
  "project": {
    "name": "Dewey",
    "description": "Execution-zone write gateway for approved mandates",
    "default_branch": "main"
  },
  "runtime": {
    "primary_mode": "docker_compose",
    "grpc_port": 50053
  },
  "commands": {
    "start": {
      "shell": "powershell",
      "cwd": ".",
      "command": "docker compose up --build -d"
    },
    "stop": {
      "shell": "powershell",
      "cwd": ".",
      "command": "docker compose down"
    },
    "test": {
      "shell": "powershell",
      "cwd": ".",
      "command": "docker compose run --rm --build dewey pytest -q"
    }
  },
  "entrypoint_files": [
    "README.md",
    "app/grpc_server.py",
    "app/executor.py",
    "app/config.py",
    "proto/dewey.proto",
    "docker-compose.yml"
  ]
}